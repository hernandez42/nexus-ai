{
  "llm": {
    "provider": "openai",
    "model": "deepseek-v4-flash",
    "apiKey": "${LLM_API_KEY}",
    "baseURL": "${LLM_BASE_URL}",
    "temperature": 0.7,
    "maxTokens": 4096
  },
  "workspaceDir": "./nexus-workspace",
  "memoryDir": "./nexus-workspace/memory",
  "logDir": "./nexus-workspace/logs",
  "modules": {
    "selfAwareness": {
      "enabled": true,
      "maxRoundsPerCycle": 1
    },
    "triOrchestrator": {
      "maxIterations": 1,
      "maxReasoningSteps": 3
    },
    "glue": {
      "superpowersToEve": true,
      "evolverToPiMono": true,
      "autoresearchToEvolver": true
    }
  },
  "repos": {
    "eve": "../eve",
    "piMono": "../pi-mono",
    "evolver": "../evolver",
    "superpowers": "../superpowers",
    "autoresearch": "../autoresearch"
  },
  "logLevel": "info",
  "persistExperiences": true
}
