{
  "llm": {
    "provider": "openai",
    "model": "${LLM_MODEL:-gpt-4o}",
    "apiKey": "${LLM_API_KEY}",
    "baseURL": "${LLM_BASE_URL}",
    "temperature": 0.7,
    "maxTokens": 4096
  },
  "workspaceDir": "./nexus-workspace",
  "memoryDir": "./nexus-workspace/memory",
  "logDir": "./nexus-workspace/logs",
  "modules": {
    "selfAwareness": {
      "enabled": true,
      "maxRoundsPerCycle": 3
    },
    "triOrchestrator": {
      "maxIterations": 3,
      "maxReasoningSteps": 8
    },
    "glue": {
      "superpowersToEve": true,
      "evolverToPiMono": true,
      "autoresearchToEvolver": true,
      "bidirectional": true
    }
  },
  "repos": {
    "eve": "${EVE_REPO:-../eve}",
    "piMono": "${PIMONO_REPO:-../pi-mono}",
    "evolver": "${EVOLVER_REPO:-../evolver}",
    "superpowers": "${SUPERPOWERS_REPO:-../superpowers}",
    "autoresearch": "${AUTORESEARCH_REPO:-../autoresearch}"
  },
  "logLevel": "info",
  "persistExperiences": true
}
