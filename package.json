{
  "name": "nexus-orchestrator",
  "version": "1.0.0",
  "description": "Unified self-evolving cognitive architecture combining Eve, Pi-Mono, Evolver, Superpowers, and AutoResearch",
  "type": "module",
  "main": "dist/nexus.js",
  "bin": {
    "nexus": "dist/nexus.js"
  },
  "scripts": {
    "start": "tsx src/nexus.ts",
    "dev": "tsx src/nexus.ts --skip-glue",
    "init": "tsx src/nexus.ts --init",
    "build": "tsc",
    "pipeline": "tsx src/pipeline.ts",
    "validate": "tsx src/validate-eve-skills.ts",
    "demo": "tsx src/triorchestrator.ts demo",
    "demo:self-aware": "tsx src/triorchestrator.ts demo --self-aware",
    "awareness": "tsx src/self-awareness.ts demo",
    "test": "echo 'Run individual demos: npm run demo | npm run awareness'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "chalk": "^5.3.0",
    "gray-matter": "^4.0.3",
    "openai": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
