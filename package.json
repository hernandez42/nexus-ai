{
  "name": "nexus-ai",
  "version": "0.3.0",
  "description": "Autonomous cognitive evolution framework — self-awareness, continuous deconstruction, genetic evolution, and persistent memory",
  "type": "module",
  "main": "dist/nexus.js",
  "bin": {
    "nexus": "dist/nexus.js"
  },
  "scripts": {
    "start": "tsx src/nexus.ts",
    "godel": "tsx src/godel-nexus.ts",
    "dev": "tsx src/nexus.ts --skip-glue",
    "init": "tsx src/nexus.ts --init",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@earendil-works/pi-agent-core": "file:../pi-mono/packages/agent",
    "eve": "file:../eve/packages/eve"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
